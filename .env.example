# ── Platform super-admin bootstrap (local only) ─────────────────────────────
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
# PLATFORM_ADMIN_PASSWORD=change_me_strong_password

# ── Database (required) ──────────────────────────────────────────────────────
# Railway otomatik sağlar: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (required in production) ──────────────────────────────────────────
# Railway otomatik sağlar: ${{Redis.REDIS_URL}}
REDIS_URL=redis://default:password@host:6379

# ── Security (required in production) ───────────────────────────────────────
# En az 32 karakter rastgele string. Örnek: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32_char_string_minimum

# ── CORS (required in production) ───────────────────────────────────────────
# Railway'deki frontend domainin. Örnek: https://guest-pro.up.railway.app
# Tek servis kullandığımız için bu API'nin kendi domaini
ALLOWED_ORIGIN=https://your-app.up.railway.app

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Proxy hops (Railway için 1 bırak) ───────────────────────────────────────
TRUST_PROXY_HOPS=1

# ── Gemini AI (opsiyonel — chat özelliği için) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Virgülle ayrılmış model zinciri (varsayılan: lite modeller önce)
# GEMINI_CHAT_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-flash-lite-latest

# ── Platform OTP email (super-admin 2FA) ─────────────────────────────────────
# Gmail: https://myaccount.google.com/apppasswords → create app password
# GMAIL_USER=ryilmazomer@gmail.com
# GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"   # quotes required if password has spaces
#
# Or generic SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=ryilmazomer@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Guest Pro" <ryilmazomer@gmail.com>

# ── Google OAuth (opsiyonel) ─────────────────────────────────────────────────
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_REDIRECT_URI=
