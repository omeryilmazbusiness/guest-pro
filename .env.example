# ── Database (required) ──────────────────────────────────────────────────────
# Railway otomatik sağlar: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis (required in production) ──────────────────────────────────────────
# Railway otomatik sağlar: ${{Redis.REDIS_URL}}
REDIS_URL=redis://default:password@host:6379

# ── Security (required in production) ───────────────────────────────────────
# En az 32 karakter rastgele string. Örnek: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32_char_string_minimum

# ── CORS (required in production) ───────────────────────────────────────────
# Railway'deki frontend domainin. Örnek: https://guest-pro.up.railway.app
# Tek servis kullandığımız için bu API'nin kendi domaini
ALLOWED_ORIGIN=https://your-app.up.railway.app

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Proxy hops (Railway için 1 bırak) ───────────────────────────────────────
TRUST_PROXY_HOPS=1

# ── Gemini AI (opsiyonel — chat özelliği için) ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth (opsiyonel) ─────────────────────────────────────────────────
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_REDIRECT_URI=
