# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# PostgreSQL bağlantı URL'si
# Lokal örnek: postgresql://postgres:password@localhost:5432/guestpro
DATABASE_URL=postgresql://postgres:password@localhost:5432/guestpro

# Session güvenlik anahtarı (en az 32 karakter, production'da değiştir)
SESSION_SECRET=guestpro_dev_secret_change_in_production_32chars

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google OAuth (opsiyonel) ─────────────────────────────────────────────────
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── CORS (production'da frontend URL'sini gir) ───────────────────────────────
# ALLOWED_ORIGIN=http://localhost:5173
# APP_BASE_URL=http://localhost:3000
