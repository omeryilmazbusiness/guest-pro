# ─── Runtime ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Required. Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://postgres:password@localhost:5432/guestpro

# PostgreSQL connection pool (optional, sane defaults shown)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# ─── Redis ────────────────────────────────────────────────────────────────────
# Required in production for rate limiting, OAuth state and scheduler locks.
# Falls back to in-memory stores when unset (development only).
REDIS_URL=redis://localhost:6379

# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED in production: min 32 chars, cryptographically random.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=guestpro_dev_secret_change_in_production_32chars_minimum

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Required in production. Set to the exact frontend origin (no trailing slash).
# ALLOWED_ORIGIN=https://app.example.com
# APP_BASE_URL=https://api.example.com

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Number of trusted reverse-proxy hops in front of the API server.
# 1 = single nginx/load-balancer, 2 = LB + nginx, 0 = no proxy (direct).
TRUST_PROXY_HOPS=1

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Required for AI concierge features.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
